<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.university.asset.mapper.AssetAllocateMapper">

    <select id="selectAllocatePage" resultType="com.university.asset.entity.AssetAllocate">
        SELECT * FROM asset_allocate WHERE deleted = 0
        <if test="deptId != null">
            AND (from_dept_id = #{deptId} OR to_dept_id = #{deptId})
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
