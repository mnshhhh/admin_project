<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.university.asset.mapper.AssetRepairMapper">

    <select id="selectRepairPage" resultType="com.university.asset.entity.AssetRepair">
        SELECT * FROM asset_repair WHERE deleted = 0
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        <if test="repairManId != null">
            AND (repair_man_id = #{repairManId} OR repair_man_id IS NULL)
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
