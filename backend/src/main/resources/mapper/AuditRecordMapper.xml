<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.university.asset.mapper.AuditRecordMapper">

    <select id="selectByBiz" resultType="com.university.asset.entity.AuditRecord">
        SELECT * FROM audit_record WHERE biz_type = #{bizType} AND biz_id = #{bizId} ORDER BY create_time DESC
    </select>

</mapper>
